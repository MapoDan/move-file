# Watched directories mounted from host
INPUT_DIR=/data/input
DIR_CLEAN=/data/clean
DIR_TAGGED=/data/tagged

# Optional recursive watch
RECURSIVE_WATCH=true

# Debounce/stability config
FILE_STABILITY_SECONDS=15
FILE_STABILITY_POLL_SECONDS=2

# Processing resilience
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5

# State persistence
PROCESSED_DB_PATH=/data/state/processed.sqlite3

# Logging
LOG_LEVEL=INFO

# set-tag.py behavior
ONETAGGER_URL=http://onetagger:8080/tag
ONETAGGER_TIMEOUT_SECONDS=60

# upload-file.py behavior
NEXTCLOUD_URL=https://nextcloud.example.com
NEXTCLOUD_USER=music-bot
NEXTCLOUD_PASSWORD=change-me
NEXTCLOUD_ROOT=/Music
DELETE_AFTER_UPLOAD=true

# Process existing files already present when container starts
STARTUP_SCAN_ENABLED=true
